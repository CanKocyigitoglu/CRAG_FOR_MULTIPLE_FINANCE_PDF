# Copy to .env and adjust. Everything defaults to local/OSS (~£0).

# --- models / providers (swappable) ---
EMBEDDING_PROVIDER=ollama            # ollama | openai | cohere
EMBEDDING_MODEL=nomic-embed-text     # 768-dim, already pulled via Ollama
LLM_PROVIDER=ollama                  # ollama | openai | anthropic | cohere
LLM_MODEL=qwen2:7b                   # already pulled via Ollama
RERANKER=local                       # local (cross-encoder) | off

# Cross-encoder model used when RERANKER=local (needs requirements-rerank.txt).
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- optional paid (leave blank to stay free) ---
OPENAI_API_KEY=
COHERE_API_KEY=
ANTHROPIC_API_KEY=

# --- infra ---
OLLAMA_URL=http://localhost:11434
# Qdrant runs EMBEDDED (on-disk) by default — no server needed.
# Leave QDRANT_URL blank for embedded mode; set it to use a Qdrant server instead.
QDRANT_URL=
QDRANT_PATH=data/qdrant              # on-disk storage for embedded mode
QDRANT_COLLECTION=finance_chunks

# Deferred to Milestone 4 (need Docker): Redis cache, RabbitMQ async ingestion.
# REDIS_URL=redis://localhost:6379
# RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# --- retrieval tuning ---
RETRIEVE_TOP_K=20                    # over-retrieve before rerank
FINAL_TOP_K=5                        # chunks passed to the LLM after rerank

# --- api ---
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:5500,http://localhost:5500
